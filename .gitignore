# ---------------------------------------------------------------------------
# Apex-Pharma .gitignore — .NET template plus project-specific rules.
# ---------------------------------------------------------------------------

# Build output
[Bb]in/
[Oo]bj/
[Dd]ebug/
[Rr]elease/
x64/
x86/
[Ww][Ii][Nn]32/
[Aa][Rr][Mm]/
[Aa][Rr][Mm]64/
build/
bld/
[Oo]ut/
msbuild.log
msbuild.err
msbuild.wrn

# Visual Studio / Rider / VS Code
.vs/
.vscode/
.idea/
*.user
*.suo
*.userosscache
*.sln.docstates
*.userprefs
*_i.c
*_p.c

# Test results
[Tt]est[Rr]esult*/
TestResults/
*.trx
*.coverage
*.coveragexml
[Cc]overage*/

# NuGet
*.nupkg
*.snupkg
**/[Pp]ackages/*
!**/[Pp]ackages/build/
*.nuget.props
*.nuget.targets

# ---------------------------------------------------------------------------
# Apex-Pharma specific
# ---------------------------------------------------------------------------

# Local SQLite database files must never be committed (patient/business data,
# and the DB is regenerated from migrations). WAL/SHM sidecar files too.
*.db
*.db-shm
*.db-wal

# Backup output folder (local + cloud staging)
backups/

# Local-only settings overrides (secrets, machine-specific config)
appsettings.*.local.json

# Large reference PDFs (source study material — kept locally, not in the repo)
*.pdf
