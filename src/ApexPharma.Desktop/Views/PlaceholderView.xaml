<UserControl x:Class="ApexPharma.Desktop.Views.PlaceholderView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid Background="White">
        <Border HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Background="#F2F4F7"
                BorderBrush="#D0D5DD"
                BorderThickness="1"
                CornerRadius="8"
                Padding="40,32">
            <StackPanel HorizontalAlignment="Center">
                <TextBlock Text="{Binding Headline}"
                           FontSize="20"
                           FontWeight="SemiBold"
                           Foreground="#344054"
                           HorizontalAlignment="Center"
                           TextAlignment="Center"
                           TextWrapping="Wrap" />
                <TextBlock Text="This module is not yet available. It will arrive in a later phase of the build."
                           FontSize="13"
                           Foreground="#667085"
                           Margin="0,10,0,0"
                           HorizontalAlignment="Center"
                           TextAlignment="Center"
                           TextWrapping="Wrap"
                           MaxWidth="360" />
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
