<UserControl x:Class="ApexPharma.Desktop.Views.InventoryView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:views="clr-namespace:ApexPharma.Desktop.Views">

    <UserControl.Resources>
        <views:StockRowBrushConverter x:Key="StockRowBrush" />
    </UserControl.Resources>

    <DockPanel LastChildFill="True" Background="White">
        <Border DockPanel.Dock="Top" Background="#0F4C81" Padding="16,10">
            <TextBlock Text="Inventory — Current Stock" Foreground="White" FontSize="18" FontWeight="Bold" />
        </Border>

        <!-- Toolbar: near-expiry window + refresh + legend -->
        <DockPanel DockPanel.Dock="Top" Margin="12,10,12,4" LastChildFill="False">
            <TextBlock Text="Near-expiry window (days):" VerticalAlignment="Center" Margin="0,0,6,0" />
            <TextBox Text="{Binding NearExpiryDays, UpdateSourceTrigger=PropertyChanged}"
                     Width="60" Padding="6,3" VerticalAlignment="Center" />
            <Button Content="Refresh" Command="{Binding RefreshCommand}" Padding="14,4" Margin="8,0,0,0"
                    Background="#0F4C81" Foreground="White" />

            <!-- Colour legend -->
            <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" VerticalAlignment="Center">
                <Border Background="#FDE2E1" Width="14" Height="14" Margin="12,0,4,0" />
                <TextBlock Text="Expired" VerticalAlignment="Center" Margin="0,0,10,0" />
                <Border Background="#FFF3CD" Width="14" Height="14" Margin="0,0,4,0" />
                <TextBlock Text="Near-expiry" VerticalAlignment="Center" Margin="0,0,10,0" />
                <Border Background="#DDEBFF" Width="14" Height="14" Margin="0,0,4,0" />
                <TextBlock Text="Low-stock" VerticalAlignment="Center" />
            </StackPanel>
        </DockPanel>

        <!-- Status summary -->
        <TextBlock DockPanel.Dock="Bottom" Text="{Binding StatusMessage}" Margin="12,6,12,10"
                   Foreground="#475467" />

        <!-- Read-only stock grid; row colour reflects expiry / low-stock status. -->
        <DataGrid Margin="12,4,12,0"
                  ItemsSource="{Binding Rows}"
                  AutoGenerateColumns="False"
                  IsReadOnly="True"
                  CanUserAddRows="False"
                  HeadersVisibility="Column"
                  GridLinesVisibility="Horizontal"
                  RowBackground="Transparent">
            <DataGrid.RowStyle>
                <Style TargetType="DataGridRow">
                    <Setter Property="Background"
                            Value="{Binding Converter={StaticResource StockRowBrush}}" />
                </Style>
            </DataGrid.RowStyle>
            <DataGrid.Columns>
                <DataGridTextColumn Header="Product" Binding="{Binding ProductName}" Width="2*" />
                <DataGridTextColumn Header="Batch" Binding="{Binding BatchNo}" Width="*" />
                <DataGridTextColumn Header="Qty" Binding="{Binding QtyOnHand, StringFormat={}{0:0.##}}" Width="0.7*" />
                <DataGridTextColumn Header="Expiry" Binding="{Binding ExpiryDate, StringFormat=d}" Width="*" />
                <DataGridTextColumn Header="MRP" Binding="{Binding Mrp, StringFormat={}{0:0.00}}" Width="0.8*" />
            </DataGrid.Columns>
        </DataGrid>
    </DockPanel>
</UserControl>
