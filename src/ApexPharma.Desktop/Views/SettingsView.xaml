<UserControl x:Class="ApexPharma.Desktop.Views.SettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:views="clr-namespace:ApexPharma.Desktop.Views">

    <UserControl.Resources>
        <views:BoolToStatusBrushConverter x:Key="StatusBrush" />
        <views:NullOrEmptyToVisibilityConverter x:Key="NullOrEmptyToVis" />

        <Style x:Key="FieldLabel" TargetType="TextBlock">
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Margin" Value="0,8,0,2" />
            <Setter Property="Foreground" Value="#344054" />
        </Style>
        <Style x:Key="FieldBox" TargetType="TextBox">
            <Setter Property="Padding" Value="6,4" />
        </Style>
    </UserControl.Resources>

    <DockPanel LastChildFill="True" Background="White">
        <Border DockPanel.Dock="Top" Background="#0F4C81" Padding="16,10">
            <TextBlock Text="Settings — Pharmacy Profile" Foreground="White" FontSize="18" FontWeight="Bold" />
        </Border>

        <!-- Status banner (success green / error red) -->
        <Border DockPanel.Dock="Bottom" Padding="16,10"
                Visibility="{Binding StatusMessage, Converter={StaticResource NullOrEmptyToVis}}">
            <TextBlock Text="{Binding StatusMessage}"
                       Foreground="{Binding IsError, Converter={StaticResource StatusBrush}}"
                       FontWeight="SemiBold"
                       TextWrapping="Wrap" />
        </Border>

        <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="20,12">
            <StackPanel MaxWidth="620" HorizontalAlignment="Left">

                <TextBlock Text="These details appear on every GST invoice / receipt. GSTIN and the drug-license number are legally required on the bill."
                           TextWrapping="Wrap" Foreground="#667085" Margin="0,0,0,6" />

                <TextBlock Text="Pharmacy name" Style="{StaticResource FieldLabel}" />
                <TextBox Text="{Binding PharmacyName, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource FieldBox}" />

                <TextBlock Text="Address line" Style="{StaticResource FieldLabel}" />
                <TextBox Text="{Binding AddressLine, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource FieldBox}" />

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" Margin="0,0,6,0">
                        <TextBlock Text="City" Style="{StaticResource FieldLabel}" />
                        <TextBox Text="{Binding City, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource FieldBox}" />
                    </StackPanel>
                    <StackPanel Grid.Column="1" Margin="6,0,0,0">
                        <TextBlock Text="State" Style="{StaticResource FieldLabel}" />
                        <TextBox Text="{Binding State, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource FieldBox}" />
                    </StackPanel>
                </Grid>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" Margin="0,0,6,0">
                        <TextBlock Text="GSTIN" Style="{StaticResource FieldLabel}" />
                        <TextBox Text="{Binding Gstin, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource FieldBox}" />
                    </StackPanel>
                    <StackPanel Grid.Column="1" Margin="6,0,0,0">
                        <TextBlock Text="Drug License No. (Form 20/21)" Style="{StaticResource FieldLabel}" />
                        <TextBox Text="{Binding DlNumber, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource FieldBox}" />
                    </StackPanel>
                </Grid>

                <TextBlock Text="Phone" Style="{StaticResource FieldLabel}" />
                <TextBox Text="{Binding Phone, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource FieldBox}" />

                <TextBlock Text="Invoice footer / terms" Style="{StaticResource FieldLabel}" />
                <TextBox Text="{Binding InvoiceFooter, UpdateSourceTrigger=PropertyChanged}"
                         Style="{StaticResource FieldBox}"
                         AcceptsReturn="True" TextWrapping="Wrap" MinHeight="48" />

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" Margin="0,0,6,0">
                        <TextBlock Text="Near-expiry alert (days)" Style="{StaticResource FieldLabel}" />
                        <TextBox Text="{Binding NearExpiryDays, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource FieldBox}" />
                    </StackPanel>
                    <StackPanel Grid.Column="1" Margin="6,0,0,0">
                        <TextBlock Text="Tax rounding" Style="{StaticResource FieldLabel}" />
                        <ComboBox ItemsSource="{Binding TaxRoundingModes}"
                                  SelectedItem="{Binding TaxRoundingMode}"
                                  Padding="6,4" />
                    </StackPanel>
                </Grid>

                <Button Content="Save settings"
                        Command="{Binding SaveCommand}"
                        HorizontalAlignment="Left"
                        Padding="16,6" Margin="0,16,0,0"
                        Background="#0F4C81" Foreground="White" FontWeight="SemiBold" />

                <!-- ===== Backup & restore (Phase 1g — plan.md §13, §14) ===== -->
                <Separator Margin="0,24,0,12" />

                <TextBlock Text="Backup &amp; restore" FontSize="16" FontWeight="Bold" Foreground="#0F4C81" />
                <TextBlock Text="Backups are AES-256 encrypted and locked to this Windows user on this PC. A backup runs automatically once a day; you can also back up on demand."
                           TextWrapping="Wrap" Foreground="#667085" Margin="0,2,0,6" />

                <TextBlock Text="{Binding Backup.LastBackupStatus}" FontWeight="SemiBold" Margin="0,4,0,8" />

                <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                    <Button Content="Backup now"
                            Command="{Binding Backup.BackupNowCommand}"
                            Padding="16,6" Margin="0,0,8,0"
                            Background="#0F4C81" Foreground="White" FontWeight="SemiBold" />
                    <Button Content="Restore from file…"
                            Command="{Binding Backup.RestoreCommand}"
                            Padding="16,6"
                            Background="#B42318" Foreground="White" FontWeight="SemiBold" />
                </StackPanel>

                <TextBlock Text="Local backup folder" Style="{StaticResource FieldLabel}" />
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBox Grid.Column="0" Text="{Binding Backup.LocalFolder, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource FieldBox}" />
                    <Button Grid.Column="1" Content="Browse…" Command="{Binding Backup.BrowseLocalCommand}" Margin="6,0,0,0" Padding="10,4" />
                </Grid>

                <TextBlock Text="Cloud-synced folder (OneDrive / Google Drive — optional)" Style="{StaticResource FieldLabel}" />
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBox Grid.Column="0" Text="{Binding Backup.CloudFolder, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource FieldBox}" />
                    <Button Grid.Column="1" Content="Browse…" Command="{Binding Backup.BrowseCloudCommand}" Margin="6,0,0,0" Padding="10,4" />
                </Grid>

                <Grid Margin="0,4,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" Margin="0,0,6,0">
                        <TextBlock Text="Keep last N backups" Style="{StaticResource FieldLabel}" />
                        <TextBox Text="{Binding Backup.RetentionCount, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource FieldBox}" />
                    </StackPanel>
                    <StackPanel Grid.Column="1" Margin="6,0,0,0" VerticalAlignment="Bottom">
                        <CheckBox Content="Automatic daily backup"
                                  IsChecked="{Binding Backup.AutoBackupEnabled}"
                                  Margin="0,0,0,6" />
                    </StackPanel>
                </Grid>

                <Button Content="Save backup settings"
                        Command="{Binding Backup.SaveBackupSettingsCommand}"
                        HorizontalAlignment="Left"
                        Padding="16,6" Margin="0,8,0,0"
                        Background="#0F4C81" Foreground="White" FontWeight="SemiBold" />

                <TextBlock Text="Optional: encrypt backups with a passphrase instead (portable across PCs — you must remember it)."
                           TextWrapping="Wrap" Foreground="#667085" Margin="0,16,0,2" />
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <PasswordBox Grid.Column="0" x:Name="PassphraseBox" Padding="6,4" />
                    <Button Grid.Column="1" Content="Set passphrase" Click="SetPassphrase_Click" Margin="6,0,0,0" Padding="10,4" />
                </Grid>

                <!-- Recent backups -->
                <TextBlock Text="Recent backups" Style="{StaticResource FieldLabel}" Margin="0,16,0,4" />
                <DataGrid ItemsSource="{Binding Backup.RecentBackups}"
                          AutoGenerateColumns="False" IsReadOnly="True"
                          HeadersVisibility="Column" GridLinesVisibility="Horizontal"
                          MaxHeight="220" Margin="0,0,0,8">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="File" Binding="{Binding FileName}" Width="*" />
                        <DataGridTextColumn Header="When" Binding="{Binding TimestampLocal, StringFormat='dd MMM yyyy HH:mm'}" Width="Auto" />
                        <DataGridTextColumn Header="Size (KB)" Binding="{Binding SizeBytes, StringFormat='{}{0:N0}'}" Width="Auto" />
                    </DataGrid.Columns>
                </DataGrid>

                <!-- Backup status banner (success green / error red) -->
                <TextBlock Text="{Binding Backup.StatusMessage}"
                           Foreground="{Binding Backup.IsError, Converter={StaticResource StatusBrush}}"
                           FontWeight="SemiBold" TextWrapping="Wrap" Margin="0,4,0,16"
                           Visibility="{Binding Backup.StatusMessage, Converter={StaticResource NullOrEmptyToVis}}" />

            </StackPanel>
        </ScrollViewer>
    </DockPanel>
</UserControl>
