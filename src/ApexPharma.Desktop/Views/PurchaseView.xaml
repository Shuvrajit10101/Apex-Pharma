<UserControl x:Class="ApexPharma.Desktop.Views.PurchaseView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:views="clr-namespace:ApexPharma.Desktop.Views">

    <UserControl.Resources>
        <views:BoolToStatusBrushConverter x:Key="StatusBrush" />
    </UserControl.Resources>

    <DockPanel LastChildFill="True" Background="White">
        <Border DockPanel.Dock="Top" Background="#0F4C81" Padding="16,10">
            <TextBlock Text="Purchase / GRN — Stock In" Foreground="White" FontSize="18" FontWeight="Bold" />
        </Border>

        <Grid Margin="12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="3*" />
                <ColumnDefinition Width="2*" />
            </Grid.ColumnDefinitions>

            <!-- Left: purchase entry -->
            <DockPanel Grid.Column="0" Margin="0,0,10,0" LastChildFill="True">

                <!-- Header fields -->
                <Grid DockPanel.Dock="Top" Margin="0,0,0,8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="2*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" Margin="0,0,6,0">
                        <TextBlock Text="Supplier" FontWeight="SemiBold" />
                        <ComboBox ItemsSource="{Binding Suppliers}" SelectedItem="{Binding SelectedSupplier}"
                                  DisplayMemberPath="Name" Margin="0,2,0,0" Padding="6,4" />
                    </StackPanel>
                    <StackPanel Grid.Column="1" Margin="0,0,6,0">
                        <TextBlock Text="Supplier invoice #" FontWeight="SemiBold" />
                        <TextBox Text="{Binding SupplierInvoiceNo, UpdateSourceTrigger=PropertyChanged}"
                                 Margin="0,2,0,0" Padding="6,4" />
                    </StackPanel>
                    <StackPanel Grid.Column="2">
                        <TextBlock Text="Invoice date" FontWeight="SemiBold" />
                        <DatePicker SelectedDate="{Binding InvoiceDate}" Margin="0,2,0,0" />
                    </StackPanel>
                </Grid>

                <!-- Line grid toolbar -->
                <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="0,0,0,4">
                    <Button Content="Add line" Command="{Binding AddLineCommand}" Padding="12,4" Margin="0,0,6,0" />
                    <Button Content="Remove line" Command="{Binding RemoveLineCommand}" Padding="12,4" />
                </StackPanel>

                <!-- Totals + actions (bottom) -->
                <Border DockPanel.Dock="Bottom" Background="#F2F4F7" Padding="10" Margin="0,8,0,0"
                        BorderBrush="#D0D5DD" BorderThickness="1" CornerRadius="4">
                    <StackPanel>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Subtotal:" FontWeight="SemiBold" Margin="0,0,6,2" />
                            <TextBlock Grid.Column="1" Text="{Binding Subtotal, StringFormat={}{0:0.00}}" />
                            <TextBlock Grid.Column="2" Text="CGST:" FontWeight="SemiBold" Margin="12,0,6,2" />
                            <TextBlock Grid.Column="3" Text="{Binding TotalCgst, StringFormat={}{0:0.00}}" />
                        </Grid>
                        <Grid Margin="0,2,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="SGST:" FontWeight="SemiBold" Margin="0,0,6,2" />
                            <TextBlock Grid.Column="1" Text="{Binding TotalSgst, StringFormat={}{0:0.00}}" />
                            <TextBlock Grid.Column="2" Text="Total:" FontWeight="Bold" Margin="12,0,6,2" />
                            <TextBlock Grid.Column="3" Text="{Binding GrandTotal, StringFormat={}{0:0.00}}" FontWeight="Bold" />
                        </Grid>
                        <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                            <Button Content="Save Purchase" Command="{Binding SaveCommand}" Padding="16,6" Margin="0,0,6,0"
                                    Background="#0F4C81" Foreground="White" />
                            <Button Content="Clear" Command="{Binding ClearCommand}" Padding="16,6" />
                        </StackPanel>
                        <TextBlock Text="{Binding StatusMessage}" TextWrapping="Wrap" Margin="0,8,0,0"
                                   Foreground="{Binding IsError, Converter={StaticResource StatusBrush}}" />
                    </StackPanel>
                </Border>

                <!-- Editable line grid -->
                <DataGrid ItemsSource="{Binding Lines}" SelectedItem="{Binding SelectedLine}"
                          AutoGenerateColumns="False" CanUserAddRows="False" HeadersVisibility="Column"
                          GridLinesVisibility="All">
                    <DataGrid.Columns>
                        <DataGridTemplateColumn Header="Product" Width="2*">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <ComboBox ItemsSource="{Binding Products}" SelectedItem="{Binding SelectedProduct, UpdateSourceTrigger=PropertyChanged}"
                                              DisplayMemberPath="Name" BorderThickness="0" />
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        <DataGridTextColumn Header="Batch #" Binding="{Binding BatchNo, UpdateSourceTrigger=PropertyChanged}" Width="*" />
                        <DataGridTemplateColumn Header="Expiry" Width="1.2*">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <DatePicker SelectedDate="{Binding ExpiryDate, UpdateSourceTrigger=PropertyChanged}" BorderThickness="0" />
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        <DataGridTextColumn Header="Qty" Binding="{Binding Qty, UpdateSourceTrigger=PropertyChanged}" Width="0.6*" />
                        <DataGridTextColumn Header="Purch." Binding="{Binding PurchasePrice, UpdateSourceTrigger=PropertyChanged}" Width="0.7*" />
                        <DataGridTextColumn Header="MRP" Binding="{Binding Mrp, UpdateSourceTrigger=PropertyChanged}" Width="0.7*" />
                        <DataGridTemplateColumn Header="GST%" Width="0.7*">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <ComboBox ItemsSource="{Binding GstRates}" SelectedItem="{Binding GstRate, UpdateSourceTrigger=PropertyChanged}"
                                              BorderThickness="0" />
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        <DataGridTextColumn Header="Line total" Binding="{Binding LineTotal, StringFormat={}{0:0.00}}" Width="0.9*" IsReadOnly="True" />
                    </DataGrid.Columns>
                </DataGrid>
            </DockPanel>

            <!-- Right: recent purchases + return -->
            <DockPanel Grid.Column="1" LastChildFill="True">
                <TextBlock DockPanel.Dock="Top" Text="Recent purchases" FontWeight="SemiBold" Margin="0,0,0,4" />

                <!-- Return panel (bottom) -->
                <Border DockPanel.Dock="Bottom" Background="#F2F4F7" Padding="10" Margin="0,8,0,0"
                        BorderBrush="#D0D5DD" BorderThickness="1" CornerRadius="4">
                    <StackPanel>
                        <TextBlock Text="Purchase return to supplier" FontWeight="SemiBold" Margin="0,0,0,4" />
                        <TextBlock Text="Returns the first batch of the selected purchase." FontSize="11"
                                   Foreground="#667085" TextWrapping="Wrap" Margin="0,0,0,6" />
                        <TextBlock Text="Return qty" FontWeight="SemiBold" />
                        <TextBox Text="{Binding ReturnQty, UpdateSourceTrigger=PropertyChanged}" Margin="0,2,0,6" Padding="6,4" />
                        <TextBlock Text="Reason" FontWeight="SemiBold" />
                        <TextBox Text="{Binding ReturnReason, UpdateSourceTrigger=PropertyChanged}" Margin="0,2,0,6" Padding="6,4" />
                        <Button Content="Process return" Command="{Binding ReturnCommand}" Padding="12,5"
                                HorizontalAlignment="Left" />
                    </StackPanel>
                </Border>

                <ListView ItemsSource="{Binding RecentPurchases}" SelectedItem="{Binding SelectedRecentPurchase}">
                    <ListView.View>
                        <GridView>
                            <GridViewColumn Header="Date" DisplayMemberBinding="{Binding InvoiceDate, StringFormat=d}" Width="80" />
                            <GridViewColumn Header="Supplier" DisplayMemberBinding="{Binding Supplier.Name}" Width="120" />
                            <GridViewColumn Header="Inv #" DisplayMemberBinding="{Binding SupplierInvoiceNo}" Width="70" />
                            <GridViewColumn Header="Total" DisplayMemberBinding="{Binding Total, StringFormat={}{0:0.00}}" Width="70" />
                        </GridView>
                    </ListView.View>
                </ListView>
            </DockPanel>
        </Grid>
    </DockPanel>
</UserControl>
