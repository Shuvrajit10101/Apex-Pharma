<UserControl x:Class="ApexPharma.Desktop.Views.PurchaseReturnView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:views="clr-namespace:ApexPharma.Desktop.Views">

    <UserControl.Resources>
        <views:BoolToStatusBrushConverter x:Key="StatusBrush" />
        <BooleanToVisibilityConverter x:Key="BoolToVis" />
    </UserControl.Resources>

    <DockPanel LastChildFill="True" Background="White">
        <Border DockPanel.Dock="Top" Background="#0F4C81" Padding="16,10">
            <TextBlock Text="Purchase Return — send goods back to supplier" Foreground="White" FontSize="18" FontWeight="Bold" />
        </Border>

        <Grid Margin="12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*" />
                <ColumnDefinition Width="3*" />
            </Grid.ColumnDefinitions>

            <!-- Left: pick a purchase -->
            <DockPanel Grid.Column="0" Margin="0,0,10,0" LastChildFill="True">
                <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="0,0,0,4">
                    <TextBlock Text="Recent purchases" FontWeight="SemiBold" VerticalAlignment="Center" />
                    <Button Content="Refresh" Command="{Binding RefreshCommand}" Padding="10,3" Margin="10,0,0,0" />
                    <Button Content="Load lines" Command="{Binding LoadLinesCommand}" Padding="10,3" Margin="6,0,0,0"
                            Background="#0F4C81" Foreground="White" />
                </StackPanel>
                <ListView ItemsSource="{Binding RecentPurchases}" SelectedItem="{Binding SelectedPurchase}">
                    <ListView.View>
                        <GridView>
                            <GridViewColumn Header="Date" DisplayMemberBinding="{Binding InvoiceDate, StringFormat=d}" Width="80" />
                            <GridViewColumn Header="Supplier" DisplayMemberBinding="{Binding Supplier.Name}" Width="120" />
                            <GridViewColumn Header="Inv #" DisplayMemberBinding="{Binding SupplierInvoiceNo}" Width="70" />
                            <GridViewColumn Header="Total" DisplayMemberBinding="{Binding Total, StringFormat={}{0:0.00}}" Width="70" />
                        </GridView>
                    </ListView.View>
                </ListView>
            </DockPanel>

            <!-- Right: returnable lines -->
            <DockPanel Grid.Column="1" LastChildFill="True">
                <Border DockPanel.Dock="Bottom" Background="#F2F4F7" Padding="10" Margin="0,8,0,0"
                        BorderBrush="#D0D5DD" BorderThickness="1" CornerRadius="4">
                    <StackPanel>
                        <TextBlock Text="Reason (optional)" FontWeight="SemiBold" />
                        <TextBox Text="{Binding Reason, UpdateSourceTrigger=PropertyChanged}" Margin="0,2,0,6" Padding="6,4" />
                        <Button Content="Confirm return" Command="{Binding ConfirmReturnCommand}" Padding="16,6"
                                HorizontalAlignment="Left" Background="#0F4C81" Foreground="White"
                                IsEnabled="{Binding PurchaseLoaded}" />
                        <TextBlock Text="{Binding StatusMessage}" TextWrapping="Wrap" Margin="0,8,0,0"
                                   Foreground="{Binding IsError, Converter={StaticResource StatusBrush}}" />
                    </StackPanel>
                </Border>

                <DataGrid ItemsSource="{Binding Lines}" AutoGenerateColumns="False" CanUserAddRows="False"
                          HeadersVisibility="Column" GridLinesVisibility="All"
                          Visibility="{Binding PurchaseLoaded, Converter={StaticResource BoolToVis}}">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Product" Binding="{Binding ProductName}" Width="2*" IsReadOnly="True" />
                        <DataGridTextColumn Header="Batch #" Binding="{Binding BatchNo}" Width="*" IsReadOnly="True" />
                        <DataGridTextColumn Header="Cost" Binding="{Binding PurchasePrice, StringFormat={}{0:0.00}}" Width="0.7*" IsReadOnly="True" />
                        <DataGridTextColumn Header="Purchased" Binding="{Binding PurchasedQty, StringFormat={}{0:0.##}}" Width="0.8*" IsReadOnly="True" />
                        <DataGridTextColumn Header="Returned" Binding="{Binding ReturnedQty, StringFormat={}{0:0.##}}" Width="0.7*" IsReadOnly="True" />
                        <DataGridTextColumn Header="Remaining" Binding="{Binding RemainingQty, StringFormat={}{0:0.##}}" Width="0.8*" IsReadOnly="True" />
                        <DataGridTextColumn Header="Return qty" Binding="{Binding ReturnQty, UpdateSourceTrigger=PropertyChanged}" Width="0.9*" />
                    </DataGrid.Columns>
                </DataGrid>
            </DockPanel>
        </Grid>
    </DockPanel>
</UserControl>
