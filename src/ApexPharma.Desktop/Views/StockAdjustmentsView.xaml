<UserControl x:Class="ApexPharma.Desktop.Views.StockAdjustmentsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:views="clr-namespace:ApexPharma.Desktop.Views">

    <UserControl.Resources>
        <views:BoolToStatusBrushConverter x:Key="StatusBrush" />
        <BooleanToVisibilityConverter x:Key="BoolToVis" />
        <views:InverseBooleanToVisibilityConverter x:Key="InverseBoolToVis" />
    </UserControl.Resources>

    <DockPanel LastChildFill="True" Background="White">
        <Border DockPanel.Dock="Top" Background="#0F4C81" Padding="16,10">
            <TextBlock Text="Stock Adjustments — breakage, count correction, expiry write-off"
                       Foreground="White" FontSize="18" FontWeight="Bold" />
        </Border>

        <!-- Status banner (bottom) -->
        <Border DockPanel.Dock="Bottom" Background="#F2F4F7" Padding="10" Margin="12,0,12,12"
                BorderBrush="#D0D5DD" BorderThickness="1" CornerRadius="4">
            <DockPanel LastChildFill="True">
                <Button DockPanel.Dock="Right" Content="Refresh" Command="{Binding RefreshCommand}" Padding="14,5" />
                <TextBlock Text="{Binding StatusMessage}" TextWrapping="Wrap" VerticalAlignment="Center"
                           Foreground="{Binding IsError, Converter={StaticResource StatusBrush}}" />
            </DockPanel>
        </Border>

        <TabControl Margin="12">

            <!-- (a) Adjust a batch -->
            <TabItem Header="Adjust a batch">
                <Grid Margin="8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="2*" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="1.4*" />
                    </Grid.ColumnDefinitions>

                    <!-- Batch picker -->
                    <DataGrid Grid.Column="0" ItemsSource="{Binding Batches}"
                              SelectedItem="{Binding SelectedBatch}"
                              AutoGenerateColumns="False" CanUserAddRows="False" IsReadOnly="True"
                              HeadersVisibility="Column" GridLinesVisibility="All" SelectionMode="Single">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Product" Binding="{Binding ProductName}" Width="2*" />
                            <DataGridTextColumn Header="Batch #" Binding="{Binding BatchNo}" Width="*" />
                            <DataGridTextColumn Header="Expiry" Binding="{Binding ExpiryDate, StringFormat={}{0:yyyy-MM-dd}}" Width="*" />
                            <DataGridTextColumn Header="On hand" Binding="{Binding QtyOnHand, StringFormat={}{0:0.##}}" Width="0.8*" />
                        </DataGrid.Columns>
                    </DataGrid>

                    <GridSplitter Grid.Column="1" Width="6" HorizontalAlignment="Center" VerticalAlignment="Stretch" Background="#EAECF0" />

                    <!-- Adjustment form -->
                    <StackPanel Grid.Column="2" Margin="10,0,0,0">
                        <TextBlock Text="Selected batch" FontWeight="SemiBold" />
                        <TextBlock Text="{Binding SelectedBatch.BatchNo, TargetNullValue='(none)'}" Margin="0,2,0,10" />

                        <CheckBox Content="Physical-count correction (set on-hand to a counted value)"
                                  IsChecked="{Binding UseCount}" Margin="0,0,0,8" />

                        <StackPanel Visibility="{Binding UseCount, Converter={StaticResource InverseBoolToVis}}">
                            <TextBlock Text="Quantity delta (negative removes, e.g. -2 for breakage)" FontWeight="SemiBold" />
                            <TextBox Text="{Binding Delta, UpdateSourceTrigger=PropertyChanged}" Padding="6,4" Margin="0,2,0,8" />
                        </StackPanel>
                        <StackPanel Visibility="{Binding UseCount, Converter={StaticResource BoolToVis}}">
                            <TextBlock Text="Counted on-hand quantity" FontWeight="SemiBold" />
                            <TextBox Text="{Binding CountedQty, UpdateSourceTrigger=PropertyChanged}" Padding="6,4" Margin="0,2,0,8" />
                        </StackPanel>

                        <TextBlock Text="Reason (required)" FontWeight="SemiBold" />
                        <TextBox Text="{Binding Reason, UpdateSourceTrigger=PropertyChanged}" Padding="6,4" Margin="0,2,0,10" />

                        <Button Content="Apply adjustment" Command="{Binding ApplyAdjustmentCommand}"
                                Padding="16,6" HorizontalAlignment="Left" Background="#0F4C81" Foreground="White" />
                    </StackPanel>
                </Grid>
            </TabItem>

            <!-- (b) Expiry write-off -->
            <TabItem Header="Expiry write-off">
                <DockPanel Margin="8" LastChildFill="True">
                    <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" Margin="0,8,0,0">
                        <Button Content="Write off selected" Command="{Binding WriteOffSelectedCommand}"
                                Padding="14,6" Margin="0,0,8,0" Background="#B42318" Foreground="White" />
                        <Button Content="Write off ALL expired" Command="{Binding WriteOffAllExpiredCommand}"
                                Padding="14,6" Background="#B42318" Foreground="White" />
                    </StackPanel>

                    <TextBlock DockPanel.Dock="Top" Margin="0,0,0,6" TextWrapping="Wrap" Foreground="#475467"
                               Text="Expired batches (expiry on or before today) still carrying stock. Writing off zeroes the lot and records an audited Expiry adjustment." />

                    <DataGrid ItemsSource="{Binding ExpiredBatches}" AutoGenerateColumns="False" CanUserAddRows="False"
                              HeadersVisibility="Column" GridLinesVisibility="All">
                        <DataGrid.Columns>
                            <DataGridCheckBoxColumn Header="Select" Binding="{Binding IsSelected, UpdateSourceTrigger=PropertyChanged}" Width="0.6*" />
                            <DataGridTextColumn Header="Product" Binding="{Binding ProductName}" Width="2*" IsReadOnly="True" />
                            <DataGridTextColumn Header="Batch #" Binding="{Binding BatchNo}" Width="*" IsReadOnly="True" />
                            <DataGridTextColumn Header="Expiry" Binding="{Binding ExpiryDate, StringFormat={}{0:yyyy-MM-dd}}" Width="*" IsReadOnly="True" />
                            <DataGridTextColumn Header="On hand" Binding="{Binding QtyOnHand, StringFormat={}{0:0.##}}" Width="0.8*" IsReadOnly="True" />
                            <DataGridTextColumn Header="Value @cost" Binding="{Binding ValueAtCost, StringFormat={}{0:0.00}}" Width="*" IsReadOnly="True" />
                            <DataGridTextColumn Header="Value @MRP" Binding="{Binding ValueAtMrp, StringFormat={}{0:0.00}}" Width="*" IsReadOnly="True" />
                        </DataGrid.Columns>
                    </DataGrid>
                </DockPanel>
            </TabItem>

            <!-- (c) Adjustment history -->
            <TabItem Header="History">
                <DataGrid Margin="8" ItemsSource="{Binding History}" AutoGenerateColumns="False" CanUserAddRows="False"
                          IsReadOnly="True" HeadersVisibility="Column" GridLinesVisibility="All">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Date" Binding="{Binding Date, StringFormat={}{0:yyyy-MM-dd HH:mm}}" Width="*" />
                        <DataGridTextColumn Header="Product" Binding="{Binding ProductName}" Width="2*" />
                        <DataGridTextColumn Header="Batch #" Binding="{Binding BatchNo}" Width="*" />
                        <DataGridTextColumn Header="Type" Binding="{Binding Type}" Width="*" />
                        <DataGridTextColumn Header="Delta" Binding="{Binding QtyDelta, StringFormat={}{0:0.##}}" Width="0.7*" />
                        <DataGridTextColumn Header="Reason" Binding="{Binding Reason}" Width="2*" />
                        <DataGridTextColumn Header="User" Binding="{Binding CreatedByName}" Width="*" />
                    </DataGrid.Columns>
                </DataGrid>
            </TabItem>

        </TabControl>
    </DockPanel>
</UserControl>
