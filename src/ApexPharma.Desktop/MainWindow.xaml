<Window x:Class="ApexPharma.Desktop.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="{Binding Title}"
        Height="600" Width="900"
        WindowStartupLocation="CenterScreen">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis" />
    </Window.Resources>

    <DockPanel LastChildFill="True">

        <!-- Header with signed-in user banner -->
        <Border DockPanel.Dock="Top" Background="#0F4C81" Padding="16,12">
            <DockPanel LastChildFill="False">
                <TextBlock Text="Apex-Pharma"
                           Foreground="White"
                           FontSize="20"
                           FontWeight="Bold"
                           DockPanel.Dock="Left" />
                <TextBlock Text="{Binding SignedInAs}"
                           Foreground="#CDE3F5"
                           FontSize="13"
                           VerticalAlignment="Center"
                           DockPanel.Dock="Right" />
            </DockPanel>
        </Border>

        <!-- Placeholder navigation (module views wired in later Phase 1 steps) -->
        <StackPanel DockPanel.Dock="Left"
                    Width="180"
                    Background="#F2F4F7"
                    Margin="0">
            <TextBlock Text="Navigation"
                       Margin="12,16,12,8"
                       FontWeight="SemiBold"
                       Foreground="#475467" />
            <Button Content="Billing" Margin="8,4" Padding="8" />
            <Button Content="Inventory" Margin="8,4" Padding="8" />
            <Button Content="Purchases" Margin="8,4" Padding="8" />
            <Button Content="Masters"
                    Margin="8,4" Padding="8"
                    Click="ManageMasters_Click"
                    Visibility="{Binding CanManageMasters, Converter={StaticResource BoolToVis}}" />
            <Button Content="Reports" Margin="8,4" Padding="8" />
            <Button Content="Settings" Margin="8,4" Padding="8" />
        </StackPanel>

        <!-- Content area -->
        <Grid>
            <TextBlock Text="Select a module to begin."
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center"
                       FontSize="16"
                       Foreground="#98A2B3" />
        </Grid>

    </DockPanel>
</Window>
