<Window x:Class="ApexPharma.Desktop.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:nav="clr-namespace:ApexPharma.Desktop.Navigation"
        Title="{Binding Title}"
        Height="600" Width="900"
        WindowStartupLocation="CenterScreen">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis" />

        <!-- Left-nav button style: highlights the active module. The button's Tag holds the
             module it navigates to; when it matches the shell's CurrentModule the item is
             painted as selected (plan.md §10 — active-nav feedback). -->
        <Style x:Key="NavButtonStyle" TargetType="Button">
            <Setter Property="Margin" Value="8,4" />
            <Setter Property="Padding" Value="8" />
            <Setter Property="HorizontalContentAlignment" Value="Left" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Foreground" Value="#344054" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                CornerRadius="4"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Left" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#E4EBF3" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <!-- Active item: Tag (the button's target module) == CurrentModule. -->
                <DataTrigger Value="True">
                    <DataTrigger.Binding>
                        <MultiBinding Converter="{StaticResource ModuleActiveConverter}">
                            <Binding Path="Tag" RelativeSource="{RelativeSource Self}" />
                            <Binding Path="DataContext.CurrentModule" RelativeSource="{RelativeSource AncestorType=Window}" />
                        </MultiBinding>
                    </DataTrigger.Binding>
                    <Setter Property="Background" Value="#0F4C81" />
                    <Setter Property="Foreground" Value="White" />
                    <Setter Property="FontWeight" Value="SemiBold" />
                </DataTrigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <DockPanel LastChildFill="True">

        <!-- Header with signed-in user banner -->
        <Border DockPanel.Dock="Top" Background="#0F4C81" Padding="16,12">
            <DockPanel LastChildFill="False">
                <TextBlock Text="Apex-Pharma"
                           Foreground="White"
                           FontSize="20"
                           FontWeight="Bold"
                           DockPanel.Dock="Left" />
                <TextBlock Text="{Binding SignedInAs}"
                           Foreground="#CDE3F5"
                           FontSize="13"
                           VerticalAlignment="Center"
                           DockPanel.Dock="Right" />
            </DockPanel>
        </Border>

        <!-- Persistent left navigation — each item swaps the content region in place. -->
        <StackPanel DockPanel.Dock="Left"
                    Width="180"
                    Background="#F2F4F7"
                    Margin="0">
            <TextBlock Text="Navigation"
                       Margin="12,16,12,8"
                       FontWeight="SemiBold"
                       Foreground="#475467" />
            <Button Content="Billing" Style="{StaticResource NavButtonStyle}"
                    Tag="{x:Static nav:NavigationModule.Billing}"
                    Command="{Binding NavigateBillingCommand}"
                    Visibility="{Binding CanDoBilling, Converter={StaticResource BoolToVis}}" />
            <Button Content="Sales Return" Style="{StaticResource NavButtonStyle}"
                    Tag="{x:Static nav:NavigationModule.SalesReturn}"
                    Command="{Binding NavigateSalesReturnCommand}"
                    Visibility="{Binding CanDoBilling, Converter={StaticResource BoolToVis}}" />
            <Button Content="Inventory" Style="{StaticResource NavButtonStyle}"
                    Tag="{x:Static nav:NavigationModule.Inventory}"
                    Command="{Binding NavigateInventoryCommand}"
                    Visibility="{Binding CanViewStock, Converter={StaticResource BoolToVis}}" />
            <Button Content="Purchases" Style="{StaticResource NavButtonStyle}"
                    Tag="{x:Static nav:NavigationModule.Purchases}"
                    Command="{Binding NavigatePurchasesCommand}"
                    Visibility="{Binding CanDoPurchases, Converter={StaticResource BoolToVis}}" />
            <Button Content="Purchase Return" Style="{StaticResource NavButtonStyle}"
                    Tag="{x:Static nav:NavigationModule.PurchaseReturn}"
                    Command="{Binding NavigatePurchaseReturnCommand}"
                    Visibility="{Binding CanDoPurchases, Converter={StaticResource BoolToVis}}" />
            <Button Content="Masters" Style="{StaticResource NavButtonStyle}"
                    Tag="{x:Static nav:NavigationModule.Masters}"
                    Command="{Binding NavigateMastersCommand}"
                    Visibility="{Binding CanManageMasters, Converter={StaticResource BoolToVis}}" />
            <Button Content="Reports" Style="{StaticResource NavButtonStyle}"
                    Tag="{x:Static nav:NavigationModule.Reports}"
                    Command="{Binding NavigateReportsCommand}"
                    Visibility="{Binding CanViewReports, Converter={StaticResource BoolToVis}}" />
            <Button Content="Settings" Style="{StaticResource NavButtonStyle}"
                    Tag="{x:Static nav:NavigationModule.Settings}"
                    Command="{Binding NavigateSettingsCommand}"
                    Visibility="{Binding CanManageSettings, Converter={StaticResource BoolToVis}}" />
        </StackPanel>

        <!-- Non-fatal status/error banner. Shown only when the view-model surfaces a
             message (e.g. a module failed to load) so navigation problems are reported in
             place instead of crashing the app (plan.md §10). -->
        <Border DockPanel.Dock="Bottom"
                Background="#FDECEA"
                BorderBrush="#F5C6CB"
                BorderThickness="0,1,0,0"
                Padding="16,10"
                Visibility="{Binding StatusMessage, Converter={StaticResource NullOrEmptyToVisibilityConverter}}">
            <TextBlock Text="{Binding StatusMessage}"
                       Foreground="#B42318"
                       TextWrapping="Wrap" />
        </Border>

        <!-- Content region — the active module's view-model is rendered here via the
             DataTemplates declared in App.xaml (module VM → view mapping). -->
        <ContentControl Content="{Binding CurrentViewModel}" />

    </DockPanel>
</Window>
