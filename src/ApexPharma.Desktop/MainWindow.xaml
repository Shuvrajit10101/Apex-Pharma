<Window x:Class="ApexPharma.Desktop.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:ApexPharma.Desktop.ViewModels"
        Title="{Binding Title}"
        Height="600" Width="900"
        WindowStartupLocation="CenterScreen">

    <Window.DataContext>
        <vm:MainViewModel />
    </Window.DataContext>

    <DockPanel LastChildFill="True">

        <!-- Header -->
        <Border DockPanel.Dock="Top" Background="#0F4C81" Padding="16,12">
            <TextBlock Text="Apex-Pharma"
                       Foreground="White"
                       FontSize="20"
                       FontWeight="Bold" />
        </Border>

        <!-- Placeholder navigation (no logic yet — wired in Phase 1) -->
        <StackPanel DockPanel.Dock="Left"
                    Width="180"
                    Background="#F2F4F7"
                    Margin="0">
            <TextBlock Text="Navigation"
                       Margin="12,16,12,8"
                       FontWeight="SemiBold"
                       Foreground="#475467" />
            <Button Content="Billing" Margin="8,4" Padding="8" />
            <Button Content="Inventory" Margin="8,4" Padding="8" />
            <Button Content="Purchases" Margin="8,4" Padding="8" />
            <Button Content="Reports" Margin="8,4" Padding="8" />
            <Button Content="Settings" Margin="8,4" Padding="8" />
        </StackPanel>

        <!-- Content area -->
        <Grid>
            <TextBlock Text="Select a module to begin."
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center"
                       FontSize="16"
                       Foreground="#98A2B3" />
        </Grid>

    </DockPanel>
</Window>
