<Window x:Class="ApexPharma.Desktop.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Apex-Pharma — Sign in"
        Height="380" Width="420"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize">

    <Grid Background="White">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Brand header -->
        <Border Grid.Row="0" Background="#0F4C81" Padding="24,20">
            <StackPanel>
                <TextBlock Text="Apex-Pharma"
                           Foreground="White"
                           FontSize="22"
                           FontWeight="Bold" />
                <TextBlock Text="Pharmacy Management System"
                           Foreground="#CDE3F5"
                           FontSize="12"
                           Margin="0,2,0,0" />
            </StackPanel>
        </Border>

        <!-- Sign-in form -->
        <StackPanel Grid.Row="1" Margin="24,20" VerticalAlignment="Top">

            <TextBlock Text="Username" FontWeight="SemiBold" Foreground="#344054" />
            <TextBox x:Name="UsernameBox"
                     Text="{Binding Username, UpdateSourceTrigger=PropertyChanged}"
                     Margin="0,4,0,12"
                     Padding="8,6"
                     FontSize="14" />

            <TextBlock Text="Password" FontWeight="SemiBold" Foreground="#344054" />
            <PasswordBox x:Name="PasswordBox"
                         Margin="0,4,0,12"
                         Padding="8,6"
                         FontSize="14"
                         KeyDown="PasswordBox_KeyDown" />

            <TextBlock x:Name="ErrorText"
                       Text="{Binding ErrorMessage}"
                       Foreground="#D92D20"
                       TextWrapping="Wrap"
                       Margin="0,0,0,12" />

            <Button x:Name="LoginButton"
                    Content="Sign in"
                    Click="LoginButton_Click"
                    Height="40"
                    Background="#0F4C81"
                    Foreground="White"
                    FontSize="14"
                    FontWeight="SemiBold"
                    Cursor="Hand" />
        </StackPanel>
    </Grid>
</Window>
